{
  "name": "Watchlist Dev",
  "build": {
    "dockerfile": "Dockerfile"
  },
  "features": {
    "ghcr.io/devcontainers/features/docker-in-docker:2": {},
    "ghcr.io/meaningful-ooo/devcontainer-features/fish:2": {}
  },
  "postCreateCommand": "dotnet restore && cd MyMusic.Client && pnpm install",
  "customizations": {
    "vscode": {
      "extensions": [
        "ms-dotnettools.csharp",
        "ms-dotnettools.vscode-dotnet-runtime",
        "bradlc.vscode-tailwindcss",
        "dbaeumer.vscode-eslint",
        "esbenp.prettier-vscode",
        "formulahendry.auto-rename-tag",
        "ms-azuretools.vscode-docker",
        "mtxr.sqltools",
        "mtxr.sqltools-driver-pg",
        "spencerwmiles.vscode-task-buttons"
      ],
      "settings": {
        "editor.formatOnSave": true,
        "editor.defaultFormatter": "esbenp.prettier-vscode",
        "[csharp]": {
          "editor.defaultFormatter": "ms-dotnettools.csharp"
        }
      }
    }
  },
  "mounts": [
    {
      "source": "mymusic-dev-dind",
      "target": "/var/lib/docker",
      "type": "volume"
    },
    {
      "source": "mymusic-dev-data",
      "target": "/app/data",
      "type": "volume"
    },
    {
      "source": "${localEnv:HOME}/.local/share/opencode/auth.json",
      "target": "/home/vscode/.local/share/opencode/auth.json",
      "type": "bind"
    },
    {
      "source": "${localEnv:HOME}/.config/opencode",
      "target": "/home/vscode/.config/opencode",
      "type": "bind"
    },
    {
      "source": "${localWorkspaceFolder}/.devcontainer/opencode.json",
      "target": "/home/vscode/.config/opencode/opencode.json",
      "type": "bind"
    },
    {
      "source": "${localEnv:HOME}/.local/share/opencode",
      "target": "/home/vscode/.local/share/opencode",
      "type": "bind"
    },
    {
      "source": "${localEnv:HOME}/.local/state/opencode",
      "target": "/home/vscode/.local/state/opencode",
      "type": "bind"
    }
  ],
  "forwardPorts": [4096, 5000, 5173, 5432]
  // "runServices": ["postgres"],
  // "dockerComposeFile": "../docker-compose.yml",
  // "service": "devcontainer",
  // "workspaceFolder": "/workspace"
}
